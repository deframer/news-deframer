FROM pgduckdb/pgduckdb:18-main

USER root

RUN apt-get update \
  && apt-get install -y --no-install-recommends postgresql-18-cron \
  && rm -rf /var/lib/apt/lists/*

ENV POSTGRES_INITDB_ARGS="--set shared_preload_libraries=pg_duckdb,pg_cron"

COPY initdb/ /docker-entrypoint-initdb.d/

USER postgres
