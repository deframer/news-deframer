{
  "name": "news-deframer",
  "version": "0.1.0",
  "description": "Objectively analyzes news articles for journalistic quality, rewriting headlines to remove bias, framing, and sensationalism.",
  "scripts": {
    "test": "jest",
    "lint": "eslint src",
    "build": "NODE_ENV=production webpack",
    "dist": "npm run clean && npm run build && cd dist/host && zip -r ../../extension.zip .",
    "openapi-client": "orval --config ./orval.config.mjs",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "dev": "echo \"Starting webpack watch. Run 'npm run type-check:watch' in a separate terminal for type checking.\" && webpack --watch",
    "pack": "cd dist/host && zip -r ../../extension.zip .",
    "clean": "rm -rf dist extension.zip"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/dom": "^10.4.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.43",
    "@types/jest": "^30.0.0",
    "@types/loglevel": "^1.6.3",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-jest": "^30.4.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "@eslint-react/eslint-plugin": "^5.8.16",
    "eslint": "^10.4.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "loglevel-plugin-prefix": "^0.8.4",
    "mini-css-extract-plugin": "^2.10.2",
    "orval": "^8.15.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "loglevel": "^1.9.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "tldts": "^7.4.2"
  }
}
