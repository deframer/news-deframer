{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "baseUrl": "..",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@frontend-shared/*": ["shared/*"],
      "@browser/*": ["browser-extension/src/*"],
      "@shared/*": ["browser-extension/src/shared/*"],
      "react": ["browser-extension/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["browser-extension/node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom/client": ["browser-extension/node_modules/@types/react-dom/client.d.ts"],
      "react-i18next": ["browser-extension/node_modules/react-i18next/index.d.ts"],
      "i18next": ["browser-extension/node_modules/i18next/index.d.ts"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["**/*.ts", "**/*.tsx", "../browser-extension/src/**/*.ts", "../browser-extension/src/**/*.tsx"]
}
